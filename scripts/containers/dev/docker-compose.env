# ======================================================================================================================
# Docker - Docker-Compose                                                   https://docs.docker.com/compose/compose-file
# ======================================================================================================================

# >>>> Project
DOCKER_CONTAINER_NAME=symfony
DOCKER_ENVIRONMENT=dev
DOCKER_PROFILES=core,utility
DOCKER_WORKDIR="/var/www/app"

# ----------------------------------------------------------------------------------------------------------------------
# Architecture - Core
# ----------------------------------------------------------------------------------------------------------------------

# >>>> Cache - Redis
REDIS_LOCALHOST_PORT=6379

# >>>> Database - PostgreSQL
POSTGRES_LOCALHOST_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=symfony
POSTGRES_PASSWORD=!ChangeMe!

# >>>> Message - RabbitMQ
RABBITMQ_LOCALHOST_PORT=5672
RABBITMQ_WEBSITE_PORT=15672

# ----------------------------------------------------------------------------------------------------------------------
# Utility
# ----------------------------------------------------------------------------------------------------------------------

# >>>> Database - pgAdmin                                                        https://hub.docker.com/r/dpage/pgadmin4
PGADMIN_WEBSITE_PORT=5450
PGADMIN_MAIL=pgadmin@example.com
PGADMIN_PW=!ChangeMe!
