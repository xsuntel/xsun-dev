# >>>> Cache - Redis                                                                       # <<<< Container's Name or IP
REDIS_HOST=dev-redis-dev
REDIS_PORT=6379

# >>>> Database - PostgreSQL                                                               # <<<< Container's Name or IP
POSTGRES_HOST=dev-postgres-dev
POSTGRES_PORT=5432

# >>>> Message - RabbitMQ                                                                  # <<<< Container's Name or IP
RABBITMQ_HOST=dev-rabbitmq-dev
RABBITMQ_PORT=5672

# >>>> Server - Nginx
NGINX_SCHEME=http
NGINX_HOST=127.0.0.1
NGINX_PORT=8080

